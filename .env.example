# ── Backend ─────────────────────────────────────────────────────────────────
# Local development database (used by uvicorn dev server)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agm_dev

# Local test database (used by pytest)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/agm_test

# Email delivery via Resend (https://resend.com)
RESEND_API_KEY=re_placeholder
RESEND_FROM_EMAIL=noreply@example.com

# CORS — must match the frontend origin exactly
# Local: http://localhost:5173
# Vercel: https://your-project.vercel.app
ALLOWED_ORIGIN=http://localhost:5173

# Session cookie signing key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change_me_to_a_random_secret

# Admin login credentials for the /admin interface
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# API base URL for the frontend.
# Local: http://localhost:8000  (Vite dev server proxies to FastAPI)
# Vercel: leave empty so requests use relative paths on the same domain
VITE_API_BASE_URL=http://localhost:8000
